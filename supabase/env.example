# =============================================================================
# MoMar · Variables de entorno para el frontend (tienda pública + admin)
# Copiar a .env (o .env.local para Vite) y completar con los valores reales.
# NUNCA commitear el archivo .env con valores reales.
# =============================================================================

# --- Supabase (obligatorias) -------------------------------------------------

# URL del proyecto Supabase. Ejemplo: https://xyzabc.supabase.co
VITE_SUPABASE_URL=https://tfpnfkigfvpvuhnxwpij.supabase.co

# Clave pública anon (safe para exponer en frontend)
# Supabase Dashboard > Project Settings > API > Project API keys > anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRmcG5ma2lnZnZwdnVobnh3cGlqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg4NTI3MTEsImV4cCI6MjA5NDQyODcxMX0.gIlRtTF9qPrGACI-xmxjzeWUydU-3U2UVMAl-Nwtvgg

# --- SIFEN Engine (solo para Edge Function o microservicio — NO exponer en cliente) ---

# URL de la API interna de NODO sifen-engine
SIFEN_ENGINE_URL=https://sifen.nodo.com.py

# API key del tenant MoMar en sifen-engine (guardar en Supabase Secrets, no en .env del frontend)
SIFEN_ENGINE_API_KEY=sk_live_...

# --- Bancard (solo backend/Edge Function) ------------------------------------

# Public key de Bancard para inicializar el checkout en el frontend
VITE_BANCARD_PUBLIC_KEY=

# URL del ambiente: https://vpos.infonet.com.py (prod) | https://vpos.infonet.com.py/checkout/new (staging)
VITE_BANCARD_CHECKOUT_URL=https://vpos.infonet.com.py/checkout/new

# Private key de Bancard — NUNCA exponer en cliente, solo en Edge Function
BANCARD_PRIVATE_KEY=

# --- Wally -------------------------------------------------------------------
# Se implementa desde el cliente (deep link / QR); no requiere variables de entorno.

# --- Meta Pixel (opcional) ---------------------------------------------------
VITE_META_PIXEL_ID=

# --- Google Tag Manager (opcional) ------------------------------------------
VITE_GTM_ID=GTM-XXXXX

# --- Misc -------------------------------------------------------------------

# Entorno: development | production
VITE_APP_ENV=development

# URL base de la tienda pública (para og:url, canonical, etc.)
VITE_APP_URL=https://momar.com.py
